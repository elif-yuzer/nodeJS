    <div class="container">
      <h1 class="mt-3">FullStack Todo Template Project</h1>
      <hr />
      <div class="rows">
        <h2>TODO LIST</h2>
        <table class="table table-striped">
          <thead>
            <tr>
              <th>ID</th>
              <th>Title</th>
              <th>Description</th>
              <th>Priority</th>
              <th>isDone</th>
              <th>CreatedAt</th>
              <th><a href="#" class="btn btn-primary">CREATE</a></th>
            </tr>
          </thead>
        <tbody>
  <% todolar.forEach(todo => { %>
    <tr>
      <td><%= todo.id %></td>
      <td><%= todo.title %></td>
      <td><%= todo.description %></td>
      <td><%= todo.priority %></td>
      <td><%= todo.isDone ? '✅' : '❌' %></td>
      <td><%= todo.createdAt %></td>
      <td></td>
    </tr>
  <% }) %>
</tbody>
        </table>
      </div>
    </div>
