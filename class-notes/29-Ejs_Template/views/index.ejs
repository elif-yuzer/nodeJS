<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Todo App</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"/>
    <style>
      table { table-layout: fixed; }
    </style>
  </head>
  <body>
    <div class="container">
      <h1 class="mt-3">FullStack Todo Template Project</h1>
      <hr />
      <div class="rows">
        <h2>TODO LIST (<%= count %>)</h2>
        <table class="table table-striped">
          <thead>
            <tr>
              <th style="width: 50px;">ID</th>
              <th style="width: 150px;">Title</th>
              <th style="width: 200px;">Description</th>
              <th style="width: 80px;">Priority</th>
              <th style="width: 80px;">isDone</th>
              <th style="width: 120px;">CreatedAt</th>
              <th style="width: 100px;">
                <a href="/view/create" class="btn btn-primary btn-sm">CREATE</a>
              </th>
            </tr>
          </thead>
          <tbody>
            <% todolar.forEach(todo => { %>
              <tr>
                <td><%= todo.id %></td>
                <td class="text-truncate" style="max-width: 150px;"><%= todo.title %></td>
                <td class="text-truncate" style="max-width: 200px;"><%= todo.description %></td>
                <td><%= PRIORITIES[todo.priority] %></td>
                <td><%- todo.isDone ? "<span class='text-success'>✅ YES</span>" : "<span class='text-danger'>❌ NO</span>" %></td>
                <td><%= todo.createdAt.toLocaleDateString('tr') %></td>
                <td>
                  <a href="/view/<%= todo.id %>" class="btn btn-info btn-sm">DETAIL</a>
                  
                  <!-- Modal açan buton -->
                  <button type="button" class="btn btn-danger btn-sm"
                    data-bs-toggle="modal"
                    data-bs-target="#deleteModal<%= todo.id %>">
                    DELETE
                  </button>
                </td>
              </tr>

              <!-- Modal tablonun DIŞINDA ama forEach içinde -->
              <div class="modal fade" id="deleteModal<%= todo.id %>" tabindex="-1">
                <div class="modal-dialog">
                  <div class="modal-content">
                    <div class="modal-header">
                      <h5 class="modal-title">Silme Onayı</h5>
                    </div>
                    <div class="modal-body">
                      <p><strong><%= todo.title %></strong> silinecek. Emin misiniz?</p>
                    </div>
                    <div class="modal-footer">
                      <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                      <form method="POST" action="/view/<%= todo.id %>?_method=DELETE">
                        <button type="submit" class="btn btn-danger">Evet, Sil</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>

            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>